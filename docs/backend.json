
{
  "entities": {
    "Submission": {
      "title": "Submission",
      "description": "بيانات طلبات هدايا Xtarmai المرسلة من المستخدمين",
      "type": "object",
      "properties": {
        "phone": {
          "type": "string",
          "description": "رقم هاتف المستخدم"
        },
        "password": {
          "type": "string",
          "description": "كلمة المرور المدخلة"
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "تاريخ الإرسال"
        },
        "status": {
          "type": "string",
          "enum": ["pending", "approved", "rejected"],
          "description": "حالة الطلب"
        }
      },
      "required": ["phone", "password", "createdAt", "status"]
    }
  },
  "auth": {
    "providers": ["anonymous"]
  },
  "firestore": {
    "/submissions/{submissionId}": {
      "schema": "#/entities/Submission",
      "description": "مجموعة تخزين طلبات هدايا Xtarmai"
    }
  }
}
